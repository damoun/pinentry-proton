# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.so.*
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool
*.out
coverage.txt
coverage.html
coverage.out
benchmark.txt
benchmark-baseline.txt
benchmark-current.txt

# Go workspace file
go.work

# Dependency directories
vendor/

# Go mod download cache
.go/pkg/mod/

# Build output
bin/
dist/
*.o

# IDE
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# Build artifacts (binaries in root directory only)
/pinentry-proton
/pinentry-proton.exe
pinentry-proton-*-*

# Environment
.env
.env.local
*.pem
*.key

# Temporary files
*.tmp
*.bak

# Test files (manual testing)
test.txt
test.txt.gpg

# Shell completion cache
.zcompdump
.zcompdump*

# Test fixtures (generated by test-setup)
test/fixtures/gnupg/
test/fixtures/ssh/

# Local test configurations (may contain vault URIs)
test-config-local.yaml
**/test-config-local.yaml

# Never commit these patterns (secrets)
*secret*.yaml
*password*.txt
